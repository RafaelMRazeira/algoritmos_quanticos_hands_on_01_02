gitignore_content = """# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribuição / Empacotamento
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Jupyter Notebooks
.ipynb_checkpoints

# Ambientes Virtuais (uv cria .venv por padrão)
.venv/
venv/
ENV/
env/

# Cache do uv (se configurado localmente ou em CI)
.uv/

# NOTA: O arquivo 'uv.lock' DEVE ser versionado no Git.
# Não o adicione ao .gitignore se estiver a desenvolver uma aplicação.

# Ferramentas de Linting, Formatação e Testes
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Variáveis de Ambiente / Segredos
.env
.env.*
!.env.example

# Configurações de IDEs (Opcional, mas recomendado)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
"""

with open(".gitignore", "w", encoding="utf-8") as f:
    f.write(gitignore_content)
print("File .gitignore created successfully.")
